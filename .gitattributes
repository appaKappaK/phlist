# Handle line endings properly
*.txt   text eol=lf
*.py    text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.csv   text eol=lf
*.json  text eol=lf

# Binary files
*.pyc   binary
*.pyo   binary
*.pyd   binary
__pycache__/* binary

# Database files (binary, stored outside repo at ~/.db/)
*.db    binary
*.sqlite binary

# Domain list formats
*.domains   text eol=lf
*.blacklist text eol=lf
*.whitelist text eol=lf
